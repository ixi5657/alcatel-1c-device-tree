on early-init
    # Mount debugfs
    mount debugfs /sys/kernel/debug /sys/kernel/debug
    
    # Enable charging in recovery
    write /sys/class/power_supply/battery/charging_enabled 1
    
    # Create directories for MTK
    mkdir /dev/ccci 0770 system system
    mkdir /dev/ccci_fs 0770 system system

on init
    # Symlinks for MTK devices
    symlink /dev/block/mmcblk0p2 /dev/nvram
    symlink /dev/block/mmcblk0p8 /dev/bootimg
    symlink /dev/block/mmcblk0p9 /dev/recovery
    
    # Battery charging
    write /sys/class/power_supply/battery/charging_enabled 1
    
    # USB configuration for recovery
    write /sys/class/android_usb/android0/enable 0
    write /sys/class/android_usb/android0/idVendor 0x0E8D
    write /sys/class/android_usb/android0/idProduct 0x2000
    write /sys/class/android_usb/android0/functions mtp,adb
    write /sys/class/android_usb/android0/enable 1

on boot
    # Permissions for radio/ccci (Modem)
    chmod 0660 /dev/ccci*
    chmod 0660 /dev/ccci_fs
    chmod 0660 /dev/ttyC*
    chown radio radio /dev/ccci*
    chown system system /dev/ccci_fs
    
    # Permissions for NVRAM
    chmod 0660 /dev/nvram
    chown system system /dev/nvram
    
    # Backlight permissions
    chmod 0666 /sys/class/leds/lcd-backlight/brightness
    
    # MT6580 specific - sensors
    chmod 0660 /dev/hwmsensor
    chmod 0660 /dev/als_ps
    chmod 0660 /dev/m_acc_misc
    chmod 0660 /dev/mag_misc
    
    # Battery
    chmod 0664 /sys/class/power_supply/battery/charging_enabled
    chmod 0664 /sys/class/power_supply/battery/battery_charging_enabled
    chmod 0664 /sys/class/power_supply/battery/capacity

on fs
    # Mount partitions
    mount ext4 /dev/block/mmcblk0p21 /system wait ro
    mount ext4 /dev/block/mmcblk0p22 /cache wait noatime
    mount ext4 /dev/block/mmcblk0p23 /data wait noatime
    mount ext4 /dev/block/mmcblk0p5 /persist wait noatime

on charger
    # Charge only mode (when phone off and USB connected)
    write /sys/class/power_supply/battery/charging_enabled 1
    class_start charger

service charger /sbin/charge_only
    class charger
    critical
    seclabel u:r:healthd:s0

service recovery /sbin/recovery
    seclabel u:r:recovery:s0

service setup_adbd /sbin/adbd
    disabled
    seclabel u:r:recovery:s0
